      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "azure-monitor-oob"
          },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "resources": [
              "__WORKSPACE_ID__"
            ],
            "resultFormat": "table",
            "dashboardTime": false,
            "query": "let runFilter = '$TestRunId';\nlet priceIn = todouble('$PriceInputPer1k');\nlet priceOut = todouble('$PriceOutputPer1k');\nlet prompt = toscalar(AppMetrics | where $__timeFilter(TimeGenerated) | where Name == 'Prompt Tokens' | extend t = tostring(Properties['Test Run ID']) | where (runFilter == '' or t == runFilter) | summarize sum(Sum));\nlet completion = toscalar(AppMetrics | where $__timeFilter(TimeGenerated) | where Name == 'Completion Tokens' | extend t = tostring(Properties['Test Run ID']) | where (runFilter == '' or t == runFilter) | summarize sum(Sum));\nprint Value = round((coalesce(prompt,0.0)/1000.0)*priceIn + (coalesce(completion,0.0)/1000.0)*priceOut, 4)"
          }
        }
      ]
    },
