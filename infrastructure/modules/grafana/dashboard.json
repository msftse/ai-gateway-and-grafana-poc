      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "azure-monitor-oob"
          },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "resources": [
              "__WORKSPACE_ID__"
            ],
            "resultFormat": "table",
            "dashboardTime": false,
            "query": "let runFilter = '$TestRunId';\nAppMetrics\n| where $__timeFilter(TimeGenerated)\n| where Name in ('Total Tokens','Prompt Tokens','Completion Tokens')\n| extend Product = tostring(Properties['Product']), TestRunId = tostring(Properties['Test Run ID']), UserId = tostring(Properties['User ID'])\n| where (runFilter == '' or TestRunId == runFilter)\n| where ('$Product' == '*' or Product == '$Product')\n| where ('$UserId' == '' or UserId == '$UserId')\n| summarize Tokens = sum(Sum) by Name\n| project Name, Tokens"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Request health",
      "id": 3,
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "azure-monitor-oob"
      },
      "gridPos": {
        "h": 6,
        "w": 10,
