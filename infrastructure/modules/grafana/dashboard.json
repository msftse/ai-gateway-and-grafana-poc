                      "value": 5
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "P95 latency (ms)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "azure-monitor-oob"
          },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "resources": [
              "__WORKSPACE_ID__"
            ],
            "resultFormat": "table",
            "dashboardTime": false,
            "query": "let runFilter = '$TestRunId';\nAppRequests\n| where $__timeFilter(TimeGenerated)\n| extend TestRunId = tostring(Properties['Request-x-test-run-id'])\n| where (runFilter == '' or TestRunId == runFilter)\n| summarize Total = count(), Errors = countif(Success == false), Throttled = countif(ResultCode == '429'), Blocked = countif(ResultCode == '403'), P95Latency = percentile(DurationMs, 95)\n| extend ErrPct = iff(Total == 0, 0.0, round(100.0 * Errors / Total, 1))\n| project ['Total requests'] = todouble(Total), ['Error %'] = ErrPct, ['Throttled (429)'] = todouble(Throttled), ['Blocked (403)'] = todouble(Blocked), ['P95 latency (ms)'] = round(P95Latency, 0)"
          }
        }
      ]
    },
