            "dashboardTime": false,
            "query": "let runFilter = '$TestRunId';\nlet priceIn = todouble('$PriceInputPer1k');\nlet priceOut = todouble('$PriceOutputPer1k');\nlet prompt = AppMetrics | where $__timeFilter(TimeGenerated) | where Name == 'Prompt Tokens' | extend Product = tostring(Properties['Product']), t = tostring(Properties['Test Run ID']) | where (runFilter == '' or t == runFilter) | summarize p = sum(Sum) by Product;\nlet completion = AppMetrics | where $__timeFilter(TimeGenerated) | where Name == 'Completion Tokens' | extend Product = tostring(Properties['Product']), t = tostring(Properties['Test Run ID']) | where (runFilter == '' or t == runFilter) | summarize c = sum(Sum) by Product;\nprompt\n| join kind=fullouter completion on Product\n| extend Product = coalesce(Product, Product1)\n| extend CostUSD = round((coalesce(p,0.0)/1000.0)*priceIn + (coalesce(c,0.0)/1000.0)*priceOut, 4)\n| project Product, ['Prompt tokens'] = p, ['Completion tokens'] = c, CostUSD\n| order by CostUSD desc"
