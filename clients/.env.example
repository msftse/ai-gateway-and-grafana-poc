# Copy to .env and fill in (the live values are written automatically by
#   terraform output  ->  clients/.env  during provisioning).
# All test scripts and run_all.py read this file.

# --- APIM AI Gateway ---
APIM_GATEWAY_URL=https://apim-aigw-xxxxxx.azure-api.net
APIM_API_PATH=openai
TEAM_A_SUBSCRIPTION_KEY=
TEAM_B_SUBSCRIPTION_KEY=

# --- Model deployments (names on the gateway/Foundry) ---
CHAT_DEPLOYMENT=gpt-4o-mini
EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Foundry project + agent (for 06_invoke_agent.py) ---
PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
AGENT_NAME=agent-aigw-demo

# --- Microsoft Learn MCP, fronted by the gateway (for the agent's MCP tool) ---
# The APIM MCP API is anonymous (subscriptionRequired=false), so the agent tool
# is published INLINE (just server_url, no connection). This is what makes the
# tool card render in the Foundry portal Playground.
# OPTIONAL governed variant: make the APIM MCP API require a subscription key,
# store that key in a Foundry project connection (Custom keys, key `api-key`),
# and set MCP_PROJECT_CONNECTION_NAME=<connection-name> below. The tool then
# authenticates via the connection (per-key rate-limit/quota) but the portal
# Tools panel will NOT render a card for it.
MCP_SERVER_URL=https://apim-aigw-xxxxxx.azure-api.net/ms-learn-mcp
MCP_SERVER_LABEL=microsoft_learn
# MCP_PROJECT_CONNECTION_NAME=learn-mcp-gateway

# --- Reference only (used by the dashboard, not required by the tests) ---
APP_INSIGHTS_CONNECTION_STRING=
RESOURCE_GROUP=rg-aigw-demo
APIM_NAME=apim-aigw-xxxxxx
WORKBOOK_PORTAL_URL=
LOCATION=swedencentral

# Azure OpenAI API version used for the data-plane calls through APIM.
OPENAI_API_VERSION=2024-10-21
